# LuxTTS Docker Environment Configuration
# =============================================================================
# WHAT: Template environment file for Docker deployment
# WHAT IT DOES: Provides default configuration values for LuxTTS container
# WHY: Centralized configuration, easy customization without rebuilding image
# =============================================================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.docker.example .env
# 2. Customize values as needed
# 3. Run: docker compose up -d
#
# NOTE: .env is mounted read-only into container for security
# =============================================================================

# -----------------------------------------------------------------------------
# MODEL SETTINGS
# -----------------------------------------------------------------------------

# HuggingFace model identifier (default: LuxTTS official model)
MODEL_PATH=YatharthS/LuxTTS

# Compute device: cuda (GPU), cpu, or mps (Apple Silicon)
# Docker default: cuda (GPU required for good performance)
DEVICE=cuda

# -----------------------------------------------------------------------------
# SERVER SETTINGS
# -----------------------------------------------------------------------------

# Server host binding (0.0.0.0 = all interfaces, required for Docker)
HOST=0.0.0.0

# Server port (default: 8000, change if port conflict)
PORT=8000

# -----------------------------------------------------------------------------
# GPU OPTIMIZATIONS (RTX 3050 4GB Specific)
# -----------------------------------------------------------------------------

# TF32: ~7x matmul speedup on Ampere GPUs (RTX 3050/3060/etc.)
# Negligible precision loss, recommended: true
ENABLE_TF32=true

# FP16 (half precision): Halves VRAM usage (~1GB model -> ~0.5GB)
# May be SLOWER on consumer GPUs due to FFT fallback
# Recommended: false for RTX 3050 (float32 is faster)
ENABLE_FP16=false

# -----------------------------------------------------------------------------
# DEFAULT TTS PARAMETERS
# These are API defaults, users can override per-request
# -----------------------------------------------------------------------------

# Audio volume/RMS (0.0 to 1.0, lower = quieter)
DEFAULT_RMS=0.001

# Sampling temperature/shift (0.0 to 1.0)
# Lower = more accurate pronunciation, higher = more expressive
DEFAULT_T_SHIFT=0.5

# Sampling steps (1 to 10)
# Higher = better quality, slower generation
DEFAULT_NUM_STEPS=4

# Speech speed multiplier (0.25 to 4.0)
DEFAULT_SPEED=1.0

# Smooth audio (reduces metallic artifacts)
DEFAULT_RETURN_SMOOTH=false

# Reference audio duration in seconds (1 to 1000)
# Duration of voice sample to use for cloning
DEFAULT_REF_DURATION=3

# -----------------------------------------------------------------------------
# ERROR HANDLING
# -----------------------------------------------------------------------------

# Auto-restart when CUDA allocator corruption detected
# WHAT: When OOM corrupts CUDA allocator, process auto-exits and Docker restarts
# WHY: Prevents manual intervention - allocator corruption breaks all requests
#      until container restart. Auto-restart restores service automatically.
# VALUES: true (auto-restart, recommended) | false (return 503 errors instead)
AUTO_RESTART_ON_CORRUPTION=true

# -----------------------------------------------------------------------------
# OPTIONAL SETTINGS
# -----------------------------------------------------------------------------

# HuggingFace token for private/gated models
# Uncomment and set if using private models
# HF_TOKEN=your_huggingface_token_here

# Maximum characters per chunk (prevents OOM on long text)
# 0 = disable chunking (single-pass, may OOM on long text)
# 200 = ~80 tokens, safe for 4GB VRAM
# DEFAULT_MAX_CHUNK_CHARS=200

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
#
# GPU REQUIREMENTS:
# - NVIDIA driver >= 525.60.13 (for CUDA 12.1)
# - NVIDIA Container Toolkit installed (Linux)
# - Docker Desktop with GPU support (Windows)
# - Verify: docker run --rm --gpus all nvidia/cuda:12.1.0-base nvidia-smi
#
# VOICE SAMPLES:
# - Place .wav or .mp3 files in voice_samples/ directory
# - Minimum 3 seconds recommended for good cloning
# - Name files as {voice_name}.wav (e.g., default.wav, sarah.wav)
# - Bind mounted at runtime (no rebuild needed to add voices)
#
# PERFORMANCE TIPS:
# - RTX 3050 4GB: Keep ENABLE_FP16=false (float32 faster)
# - Long text: Use max_chunk_chars=200 to prevent OOM
# - Slow generation: Reduce num_steps (4 is default, 2 is faster)
# - AUTO_RESTART_ON_CORRUPTION=true: Automatic recovery from OOM corruption
#
# =============================================================================